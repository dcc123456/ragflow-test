# ===============================================
# RagFlow 测试配置模板
# ===============================================
# 复制此文件为 .env 并填入真实值
# 请勿将 .env 文件提交到版本控制系统
# ===============================================

# ========== 测试环境配置 ==========
# 测试环境基础URL
TEST_URL=http://localhost:9222
# Billing测试环境URL（可选，如与TEST_URL不同）
# BILLING_URL=http://192.168.1.23:9223

# ========== 测试账号配置 ==========
# 通用测试账号邮箱（用于login和add-llm测试）
TEST_EMAIL=dcc-test1@gmail.com
# 通用测试账号密码
TEST_PASSWORD=123456

# Billing测试专用账号
# BILLING_EMAIL=yuzhichang@gmail.com
# BILLING_PASSWORD=123456

# ========== API Key 配置 ==========
# SILICONFLOW API Key（用于add-llm测试）
# 申请地址: https://platform.siliconflow.cn/
TEST_API_KEY=your-siliconflow-api-key-here

# OpenAI API Key（备用）
# OPENAI_API_KEY=your-openai-api-key-here

# ========== LLM 模型配置 ==========
# 默认LLM模型
LLM_MODEL=Qwen/Qwen2.5-72B-Instruct-128Kt
# 默认Embedding模型
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L12-v2

# ========== Stripe 测试卡配置 ==========
# Stripe测试卡信息（使用Stripe官方测试卡号）
# 测试卡号: 4242 4242 4242 4242
TEST_CARD_NAME=test-user
TEST_CARD_NUMBER=4242424242424242
TEST_CARD_EXPIRY=12/26
TEST_CARD_CVC=123
TEST_CARD_ZIP=12345

# ========== 飞书通知配置 ==========
# 飞书机器人Webhook地址
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# ========== 测试资源路径 ==========
# 截图保存目录（可选，默认使用项目根目录下的screenshots）
# SCREENSHOTS_DIR=./screenshots
# 测试结果目录（可选）
# TEST_RESULTS_DIR=./test-results
# 测试报告目录（可选）
# TEST_REPORTS_DIR=./test-reports

# ========== 浏览器配置 ==========
# 是否启用无头模式（true/false）
# HEADLESS=false
